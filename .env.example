# Polymarket CLOB API credentials
# Obtain from: https://polymarket.com/settings (Builder Settings)
POLY_API_KEY=your-api-key-here
POLY_SECRET=your-secret-here
POLY_PASSPHRASE=your-passphrase-here

# Your Polymarket proxy wallet address
POLY_WALLET_ADDRESS=0xYourWalletAddressHere

# Optional: Binance API (public endpoints only, no auth needed for price feed)
BINANCE_API_KEY=
BINANCE_SECRET=
